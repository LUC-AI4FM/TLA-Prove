# ChatTLA .gitignore

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# Training artefacts (large — don't commit to repo)
outputs/

# Upstream git mirrors (re-harvest anytime; commits recorded in tla_descriptions*.json)
data/external/

# PDF fetch cache (re-harvest rebuilds; can be large)
data/derived/.pdf_cache/

# Data (large — managed separately)
data/raw/
data/validated/
data/rejected/
data/processed/

# Keep these data files
!data/benchmarks/
!data/benchmarks/**

# MLflow
mlruns/
mlflow.db
mlartifacts/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Java class files that might get generated alongside SANY
*.class

# Byte-compiled / optimized
*.pyc
train.log
outputs/gguf_backup/chattla-20b-pre-c39.gguf
