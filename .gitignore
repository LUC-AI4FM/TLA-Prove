# ChatTLA .gitignore

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# Training artefacts (large — don't commit to repo)
outputs/gguf/
outputs/gguf_backup/
outputs/merged_model/
outputs/merged-llama3b/
outputs/checkpoints/
outputs/checkpoints_*/
outputs/checkpoints-llama3b/
outputs/llama.cpp/
outputs/toy-math/

# Backup train.jsonl files from experiments
data/processed/train.jsonl.backup_*

# Upstream git mirrors (re-harvest anytime; commits recorded in tla_descriptions*.json)
data/external/

# PDF fetch cache (re-harvest rebuilds; can be large)
data/derived/.pdf_cache/

# Data (large — managed separately)
data/raw/
data/validated/
data/rejected/
data/processed/

# Keep these data files
!data/benchmarks/
!data/benchmarks/**

# MLflow
mlruns/
mlflow.db
mlartifacts/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Java class files that might get generated alongside SANY
*.class

# Byte-compiled / optimized
*.pyc
train.log
src/shared/apalache/
src/shared/tlaps/
outputs/logs/watchdog.log
outputs/logs/sft_*.log
outputs/logs/eval_*.log
outputs/logs/merge_*.log
outputs/logs/convert_*.log
outputs/logs/publish_hf_*.log
outputs/checkpoints_v13_premerge/
outputs/merged_model_v14/
outputs/merged_model_v13_baseline/

# LaTeX build artifacts
docs/*.aux
docs/*.log
docs/*.out
docs/*.pdf
docs/*.toc
docs/*.bbl
docs/*.blg
docs/*.fls
docs/*.fdb_latexmk
docs/*.synctex.gz

# TLAPS prover training (large source corpus + scan outputs)
data/FormaLLM/
outputs/tlaps_*.json
