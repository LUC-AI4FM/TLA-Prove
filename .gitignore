# ChatTLA .gitignore

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# Training artefacts (large — don't commit to repo)
# Patterns without trailing slash also match symlinks to external storage.
outputs/gguf
outputs/gguf_backup
outputs/merged_model
outputs/merged_model_*
outputs/merged-llama3b
outputs/checkpoints
outputs/checkpoints_*
outputs/checkpoints-llama3b
outputs/llama.cpp
outputs/toy-math

# Backup train.jsonl files from experiments
data/processed/train.jsonl.backup_*

# Upstream git mirrors (re-harvest anytime; commits recorded in tla_descriptions*.json)
data/external/

# PDF fetch cache (re-harvest rebuilds; can be large)
data/derived/.pdf_cache/

# Data (large — managed separately)
data/raw/
data/validated/
data/rejected/
data/processed/

# Keep these data files
!data/benchmarks/
!data/benchmarks/**

# MLflow
mlruns/
mlflow.db
mlartifacts/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Java class files that might get generated alongside SANY
*.class

# Byte-compiled / optimized
*.pyc
train.log
src/shared/apalache/
src/shared/tlaps/
outputs/logs/*.log

# Ad-hoc 3-shot TLC+TLAPS eval debug artifacts (per-run dumps; not tracked
# across versions like the holdout_*.json results are)
outputs/eval/3shot_dumps/
outputs/eval/3shot_*.json

outputs/checkpoints_v13_premerge/
outputs/merged_model_v14/
outputs/merged_model_v13/
outputs/merged_model_v13_baseline/
outputs/merged_model_dpo_piecewise/

# Prompt sweep raw artifacts (summary CSV/JSON tracked; per-run bulk is not)
outputs/prompt_sweep/raw/
outputs/prompt_sweep/tla/
outputs/prompt_sweep/logs/

# LaTeX build artifacts
docs/*.aux
docs/*.log
docs/*.out
docs/*.pdf
docs/*.toc
docs/*.bbl
docs/*.blg
docs/*.fls
docs/*.fdb_latexmk
docs/*.synctex.gz

# TLAPS prover training (large source corpus + scan outputs)
data/FormaLLM/
outputs/tlaps_*.json
