#!/bin/bash
# Triage-only int8 eval of full-spec phase-1 checkpoints on a fixed holdout.
# This is not a publish/promote gate; keep BF16 evals queued for final evidence.
# Set the project/account at submit time if your site requires one.
#PBS -q single-gpu
#PBS -l select=1:ngpus=1:ncpus=32:mem=120gb
#PBS -l walltime=03:00:00
#PBS -l filesystems=home_fs:grand_fs
#PBS -N eval_fullspec_p1_i8
#PBS -j oe

set -euo pipefail
cd "$PBS_O_WORKDIR"

PBS_JOBNUM="${PBS_JOBID%%.*}"
ARTIFACT_ROOT="${CHATTLA_ARTIFACT_ROOT:-$PBS_O_WORKDIR/outputs/artifacts/fullspec}"
LOG_DIR="$ARTIFACT_ROOT/logs"
mkdir -p "$LOG_DIR" outputs/eval
exec > "$LOG_DIR/eval_fullspec_phase1_int8_${PBS_JOBNUM}.log" 2>&1

export HF_HOME="${HF_HOME:-${CHATTLA_HF_HOME:-$HOME/.cache/huggingface}}"
export TRANSFORMERS_CACHE="$HF_HOME"
export HF_DATASETS_CACHE="$HF_HOME/datasets"
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export HF_DATASETS_OFFLINE=1
export NUMEXPR_MAX_THREADS=32
export NUMEXPR_NUM_THREADS=16
export OMP_NUM_THREADS=8
export MKL_NUM_THREADS=8
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

PY="${CHATTLA_PYTHON:-python3}"
MODEL="${CHATTLA_BASE_MODEL:-EricSpencer00/chattla-20b}"
PHASE_JOB="${PHASE_JOB:-160343}"
PHASE_DIR="$ARTIFACT_ROOT/${PHASE_JOB}/checkpoints_grpo_fullspec_phase1_${PHASE_JOB}"
HOLDOUT=data/processed/diamond_eval_holdout.jsonl
MAX_EXAMPLES=10

echo "===== job ${PBS_JOBID:-unknown} on $(hostname) ====="
date
echo "TRIAGE=int8"
echo "MODEL=$MODEL"
echo "ARTIFACT_ROOT=$ARTIFACT_ROOT"
echo "PHASE_DIR=$PHASE_DIR"
echo "HOLDOUT=$HOLDOUT"
echo "MAX_EXAMPLES=$MAX_EXAMPLES"

echo
echo "===== GPUs ====="
nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv

echo
echo "===== Python syntax check ====="
"$PY" -m py_compile scripts/eval_fullspec_checkpoints.py

echo
echo "===== Eval base model int8 ====="
"$PY" -u -m scripts.eval_fullspec_checkpoints \
  --model "$MODEL" \
  --label base-int8 \
  --holdout "$HOLDOUT" \
  --max-examples "$MAX_EXAMPLES" \
  --max-new-tokens 1024 \
  --chat-template-reasoning-effort none \
  --timeout 20 \
  --load-in-8bit \
  --out "outputs/eval/fullspec_phase1_int8_base_${PBS_JOBNUM}.json"

for step in 20 40 60; do
  CANDIDATE="${PHASE_DIR}/checkpoint-${step}"
  if [[ ! -d "$CANDIDATE" ]]; then
    echo "skip missing $CANDIDATE"
    continue
  fi
  echo
  echo "===== Eval checkpoint-${step} int8 ====="
  "$PY" -u -m scripts.eval_fullspec_checkpoints \
    --model "$MODEL" \
    --adapter "$CANDIDATE" \
    --label "checkpoint-${step}-int8" \
    --holdout "$HOLDOUT" \
    --max-examples "$MAX_EXAMPLES" \
    --max-new-tokens 1024 \
    --chat-template-reasoning-effort none \
    --timeout 20 \
    --load-in-8bit \
    --out "outputs/eval/fullspec_phase1_int8_ckpt${step}_${PBS_JOBNUM}.json"
done

echo
echo "===== Int8 Summary ====="
"$PY" - <<'PY'
import glob
import json
from pathlib import Path

paths = sorted(glob.glob("outputs/eval/fullspec_phase1_int8_*_*.json"))
for path in paths:
    with open(path) as f:
        data = json.load(f)
    print(
        Path(path).name,
        data["label"],
        "quant", data.get("quantization"),
        "n", data["n"],
        "sany", data["sany_pass"],
        "depth1", data["depth1_pass"],
        "tlc", data["tlc_pass"],
        "mean_reward", data["mean_reward"],
        "starts_module", data["starts_module"],
        "terminator", data["has_terminator"],
        "module_match", data["module_match"],
        "syntax_issue_rows", data.get("syntax_issue_rows"),
        "syntax_issue_count", data.get("syntax_issue_count"),
    )
PY

echo
echo "===== full-spec checkpoint int8 eval done ====="
date
