# ChatTLA — Environment Variables
# Copy to .env and fill in values.  Never commit .env to git.
#
# Bash:  set -a && source .env && set +a
# Bootstrap venv + deps:  ./scripts/launch_rl.sh setup

# --- Hugging Face Hub (RL loop publish after retrain) ----------------------
# HF_TOKEN=hf_xxxxxxxx
# Optional: require a recent full benchmark CSV before Hub upload (hours)
# CHATTLA_PUBLISH_REQUIRE_BENCHMARK_HOURS=72
# Optional: upload merged BF16 folder (~40GB+) to merged_bf16/ on the Hub
# CHATTLA_HF_UPLOAD_MERGED=0

# --- GitHub API tokens (for Phase 1 scraping) ------------------------------
# Authenticated search: 30 req/min.  Multiple tokens are rotated round-robin.
GITHUB_TOKEN_1=ghp_your_token_here
# GITHUB_TOKEN_2=ghp_optional_second_token
# GITHUB_TOKEN_3=ghp_optional_third_token
# GITHUB_TOKEN_4=ghp_optional_fourth_token

# --- Ollama ----------------------------------------------------------------
# Host for local Ollama daemon.  Default is http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# --- Model selection -------------------------------------------------------
# Model used for annotation (Phase 1) and inference (Phase 3)
# ANNOTATION_MODEL=gpt-oss:20b
# CHATTLA_MODEL=chattla:20b

# --- GPU assignment --------------------------------------------------------
# Pin fine-tuning to GPU 1 (GPU 0 is in use)
# This is also set programmatically in train.py, but you can override here.
# CUDA_VISIBLE_DEVICES=1

# --- Annotation rate limiting ----------------------------------------------
# Seconds between Ollama requests during annotation pass
# ANNOTATION_DELAY_S=0.5

# --- MLflow ----------------------------------------------------------------
# MLFLOW_TRACKING_URI=http://localhost:5000

# --- Alerting (scripts/alerting.py) ----------------------------------------
# SMTP email alerts from the RL watchdog / retrain pipeline. Leave unset to
# disable alerting entirely (send_email short-circuits when SMTP_USER="").
# CHATTLA_SMTP_HOST=smtp.gmail.com
# CHATTLA_SMTP_PORT=587
# CHATTLA_SMTP_USER=you@example.com
# CHATTLA_SMTP_TO=you@example.com
# CHATTLA_SMTP_PASSWORD=your_app_password  # or put in ~/.chattla_smtp_password
